{% render 'partials/head.liquid' %}
<header>
    <nav>
        <a href="/">
            <img class="logo" src="assets/logoPink.svg" alt="logo">
        </a>
        

        <div class="list-logo">
            <a href="/wishlist"><img class="list-line" src="assets/listLine.svg" alt="list"></a>
        </div>
        {% comment %} <img class="login-logo" src="assets/loginLogo.svg" alt="login"> {% endcomment %}
    </nav>
</header>

<div class="divider"></div>

<h1>Ik zoek een cadeau voor... <span>Mijn Moeder</span></h1>
<div class="grey-background"></div>

<div class="divider"></div>

<main>
    
    <img class="filter" src="assets/filter.svg" alt="filter">

    <div class="card-container">
        
        {% for product in products %}

            {% comment %}
                Door append: '' te gebruiken kunnen er beide waarden veilig vergeleken worden.
            {% endcomment %}
            {% assign currentId = product.id | append: '' %}

            {% comment %}
                Toon de succesmelding alleen wanneer:

                1. De URL aangeeft dat het opslaan gelukt is
                2. Het huidige product hetzelfde ID heeft als het opgeslagen product

                Hierdoor verschijnt de melding alleen bij het juiste kaartje.
            {% endcomment %}
    
            {% if status == 'success' and savedProductId == currentId %}
            <output class="succes">
                <p>Toegevoegd aan je lijst!</p>
            </output>
            {% endif %}

            
            <section class="card">
                <img class="cadeau-bow" src="assets/cadeau-top.svg" alt="afbeelding van de stikjes">

                {% comment %} met een form element kan ik een method="POST" toevoegen en de cadeautjes opslaan in een lijst. {% endcomment %}

                <form action="/{{ product.id }}" method="POST">
                    <button>
                        <img class="cadeau-list" alt="Voeg toe aan lijst" src="assets/cadeauLijst.svg" />
                    </button>
                </form>

`
                <img class="product-image" src="{{ product.image }}" width="{{ img.width }}" height="{{ img.height }}" alt="product">

                <div class="card-line"></div>

                <h2 class="product-name">{{ product.name }}</h2>

                <p class="product-amount">{{ product.amount }}</p>

                <a href="/cadeaus">Bekijk cadeau</a>
            </section>
            
        {% endfor %}
    </div> 

</main>   

{% render 'partials/foot.liquid' %}